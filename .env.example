# Application
APP_NAME=NutrientrenaAPI
DEBUG=false

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=nutrientrena

# JWT
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cloudflare R2 (compatible con S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=nutrientrena-files

# CORS — orígenes permitidos para la API
# En producción poner la URL exacta del frontend (sin / al final).
# Si se omite, usa FRONTEND_URL automáticamente cuando no es localhost.
# Para dev local dejar en blanco (equivale a "*").
ALLOWED_ORIGINS=https://tudominio.up.railway.app

# Email (Resend)
RESEND_API_KEY=re_...
MAIL_FROM=onboarding@resend.dev
FRONTEND_URL=https://tudominio.up.railway.app
AWS_ENDPOINT_URL=https://77925e3b1a6f6513bce155f71f6aa790.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-397ed3b6f1d1480d8c17d960513a3c78.r2.dev
